# -----------------------------------------------
# Copia este archivo como .env y ajusta los valores
# -----------------------------------------------

# --- Seguridad ---
API_KEY=changeme

# --- Provider de datos ---
# "mock"  → datos de stub (no hace llamadas de red, ideal para desarrollo)
# "pnp"   → scraper real contra sistemaspnp.com
PROVIDER=mock
SOURCE_URL=https://www.sistemaspnp.com/cedula
REQUEST_TIMEOUT=10.0
USER_AGENT=Mozilla/5.0 (compatible; verificador-cedula/0.1)

# --- Caché ---
CACHE_TTL_SECONDS=3600

# --- Logging ---
LOG_LEVEL=INFO

# --- Persistencia histórica (próxima iteración) ---
HISTORY_ENABLED=false
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/cedula_db

# --- CORS ---
# Para múltiples orígenes: CORS_ORIGINS=["https://mi-frontend.com","https://otro.com"]
CORS_ORIGINS=["*"]
